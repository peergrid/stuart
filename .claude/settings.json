{
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(go *)",
      "Bash(ls *)",
      "Bash(mkdir *)",
      "Bash(chmod *)",
      "Bash(cat *)",
      "Bash(wc *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(jq *)",
      "Bash(rm *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(diff *)",
      "Bash(sort *)",
      "Bash(touch *)",
      "Bash(find *)",
      "Bash(which *)",
      "Bash(stat *)",
      "Bash(realpath *)",
      "Bash(du *)",
      "Bash(make *)",
      "Bash(echo *)",
      "Bash(bash *)",
      "Bash(sh *)",
      "Edit",
      "Write",
      "WebSearch",
      "WebFetch",
      "mcp__plugin_context7_context7__*"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(git push --force*)",
      "Bash(git push * --force*)",
      "Bash(git push -f *)",
      "Bash(git push * -f *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "doreen/hooks/shell-tool-misuse.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "doreen/hooks/polling-patterns.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "doreen/hooks/heredoc-script-abuse.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "doreen/hooks/undelegated-work.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "UserPromptSubmit": []
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": true,
    "hookify@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true
  }
}
